<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>404 – <%= pageTitle %></title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #ffffff; --card: #f4f4f6; --border: rgba(0,0,0,0.08);
      --text: #111114; --muted: #666672; --accent: #5a4ee8; --accent2: #1aaa88; --danger: #e05252;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #1e1e22; --card: #313138; --border: rgba(255,255,255,0.08);
        --text: #e8e8ec; --muted: #8a8a98; --accent: #7c6ff7; --accent2: #4fcfae; --danger: #f27474;
      }
    }
    body {
      background: var(--bg); color: var(--text);
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh; display: flex;
      align-items: center; justify-content: center;
      padding: 2rem 1.5rem;
    }
    .page { width: 100%; max-width: 420px; text-align: center; animation: fadeUp 0.3s ease both; }
    .logo {
      font-family: 'Space Mono', monospace; font-size: 2.4rem;
      font-weight: 700; letter-spacing: -2px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .logo-line {
      width: 50px; height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      margin: 0.5rem auto 1.5rem; border-radius: 2px;
    }
    .code {
      font-family: 'Space Mono', monospace; font-size: 5rem;
      font-weight: 700; color: var(--danger); line-height: 1;
      margin-bottom: 0.5rem;
    }
    .title { font-size: 1.1rem; font-weight: 600; margin-bottom: 0.4rem; }
    .desc  { font-size: 0.85rem; color: var(--muted); margin-bottom: 2rem; }
    .desc span { color: var(--accent); font-family: 'Space Mono', monospace; font-size: 0.8rem; }
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 0.75rem 1.5rem; border-radius: 12px; border: none;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      color: #fff; font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem; font-weight: 600; text-decoration: none;
      transition: opacity 0.15s, transform 0.1s;
    }
    .btn:hover  { opacity: 0.9; }
    .btn:active { transform: scale(0.98); }
    .btn svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
<div class="page">
  <div class="logo"><%= logoName %></div>
  <div class="logo-line"></div>
  <div class="code">404!</div>
  <div class="title">Page not found</div>
  <div class="desc"><span><%= page %></span> page doesn't exist on this website.</div>
  <a href="/" class="btn">
    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
    Go to main
  </a>
</div>
</body>
</html>
