<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Quizer — History</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #ffffff;
      --surface:   #f4f4f6;
      --card:      #f4f4f6;
      --card-hover:#eaeaef;
      --border:    rgba(0,0,0,0.08);
      --border-h:  rgba(0,0,0,0.18);
      --text:      #111114;
      --muted:     #666672;
      --accent:    #5a4ee8;
      --accent2:   #1aaa88;
      --win:       #1aaa88;
      --lose:      #e85a5a;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg:        #1e1e22;
        --surface:   #28282e;
        --card:      #313138;
        --card-hover:#3a3a44;
        --border:    rgba(255,255,255,0.08);
        --border-h:  rgba(255,255,255,0.18);
        --text:      #e8e8ec;
        --muted:     #8a8a98;
        --accent:    #7c6ff7;
        --accent2:   #4fcfae;
        --win:       #4fcfae;
        --lose:      #f27474;
      }
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      flex-direction: column;
    }

    /* ── Top Bar ── */
    .topbar {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 1.4rem 1.5rem 0;
      max-width: 560px;
      margin: 0 auto;
    }

    .back-btn {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      background: var(--card);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s;
      flex-shrink: 0;
    }
    .back-btn:hover {
      background: var(--card-hover);
      border-color: var(--border-h);
    }
    .back-btn svg {
      width: 18px;
      height: 18px;
      stroke: var(--text);
      fill: none;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .topbar-title {
      font-family: 'Space Mono', monospace;
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Page ── */
    .page {
      max-width: 560px;
      margin: 0 auto;
      padding: 1.4rem 1.5rem 3rem;
    }

    /* ── Stats Row ── */
    .stats {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 10px;
      margin-bottom: 1.5rem;
    }

    .stat-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1rem 0.8rem;
      text-align: center;
    }
    .stat-number {
      font-family: 'Space Mono', monospace;
      font-size: 1.6rem;
      font-weight: 700;
      line-height: 1;
      margin-bottom: 4px;
    }
    .stat-number.accent  { color: var(--accent); }
    .stat-number.win     { color: var(--win); }
    .stat-number.lose    { color: var(--lose); }
    .stat-label {
      font-size: 0.7rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* ── Section Title ── */
    .section-title {
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--muted);
      margin-bottom: 10px;
    }

    /* ── History List ── */
    .history-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .quiz-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1rem 1.1rem;
      display: flex;
      align-items: center;
      gap: 14px;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s, transform 0.15s;
      text-decoration: none;
      color: inherit;
      position: relative;
      overflow: hidden;
    }
    .quiz-card:hover {
      background: var(--card-hover);
      border-color: var(--border-h);
      transform: translateY(-2px);
    }
    .quiz-card:active { transform: translateY(0); }

    /* الشريط الجانبي اللي بيدل على النتيجة */
    .quiz-card::after {
      content: '';
      position: absolute;
      left: 0;
      top: 20%;
      height: 60%;
      width: 3px;
      border-radius: 0 2px 2px 0;
    }
    .quiz-card.win::after  { background: var(--win); }
    .quiz-card.lose::after { background: var(--lose); }

    /* أيقونة نوع الـ quiz */
    .quiz-icon {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 1.2rem;
    }
    .quiz-icon.science  { background: rgba(90,78,232,0.12); }
    .quiz-icon.math     { background: rgba(26,170,136,0.12); }
    .quiz-icon.history  { background: rgba(242,196,111,0.12); }
    .quiz-icon.sports   { background: rgba(242,116,116,0.12); }
    .quiz-icon.general  { background: rgba(130,130,160,0.12); }

    /* Info */
    .quiz-info { flex: 1; min-width: 0; }
    .quiz-name {
      font-size: 0.92rem;
      font-weight: 500;
      margin-bottom: 3px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .quiz-meta {
      font-size: 0.72rem;
      color: var(--muted);
    }

    /* Score Badge */
    .quiz-score {
      text-align: right;
      flex-shrink: 0;
    }
    .score-num {
      font-family: 'Space Mono', monospace;
      font-size: 0.95rem;
      font-weight: 700;
    }
    .score-num.win  { color: var(--win); }
    .score-num.lose { color: var(--lose); }
    .score-label {
      font-size: 0.68rem;
      color: var(--muted);
    }

    /* ── Empty State ── */
    .empty {flex-direction: column;
      text-align: center;
      padding: 3rem 1rem;
      color: var(--muted);
    }
    .empty svg {
      width: 48px;
      height: 48px;
      stroke: var(--border-h);
      fill: none;
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
      margin-bottom: 1rem;
    }
    .empty-title { font-size: 0.95rem; font-weight: 500; margin-bottom: 4px; color: var(--text); }
    .empty-desc  { font-size: 0.8rem; }

    /* ── Animations ── */
    .quiz-card {
      animation: fadeUp 0.3s ease both;
    }
    .quiz-card:nth-child(1) { animation-delay: 0.05s; }
    .quiz-card:nth-child(2) { animation-delay: 0.10s; }
    .quiz-card:nth-child(3) { animation-delay: 0.15s; }
    .quiz-card:nth-child(4) { animation-delay: 0.20s; }
    .quiz-card:nth-child(5) { animation-delay: 0.25s; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .stat-card {
      animation: fadeUp 0.3s ease both;
    }
    .stat-card:nth-child(1) { animation-delay: 0.0s; }
    .stat-card:nth-child(2) { animation-delay: 0.05s; }
    .stat-card:nth-child(3) { animation-delay: 0.10s; }
  </style>
</head>
<body>

  <!-- Top Bar -->
  <div class="topbar">
    <a href="/home" class="back-btn">
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
    </a>
    <span class="topbar-title">History</span>
  </div>

  <div class="page">

    <!-- Stats - الأرقام دي هتيجي من الـ server -->
    <div class="stats">
      <div class="stat-card">
        <div class="stat-number accent" id="stat-total">0</div>
        <div class="stat-label">Total</div>
      </div>
      <div class="stat-card">
        <div class="stat-number win" id="stat-wins">0</div>
        <div class="stat-label">Wins</div>
      </div>
      <div class="stat-card">
        <div class="stat-number lose" id="stat-losses">0</div>
        <div class="stat-label">Losses</div>
      </div>
    </div>

    <!-- List -->
    <div class="section-title">Recent Quizzes</div>

    <div class="history-list" id="history-list">
      <!-- الكروت هتتضاف هنا من الـ server -->
    </div>

    <!-- Empty State -->
    <div class="empty" id="empty-state">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <div class="empty-title">No quizzes yet</div>
      <div class="empty-desc">Your quiz history will appear here</div>
    </div>

<script type="module">
  import { initializeApp }               from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js';
  import { getAuth, onAuthStateChanged } from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js';
  import { getFirestore, collection, query, where, orderBy, getDocs } from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js';

  const app  = initializeApp({
    apiKey:            "AIzaSyC_bAMVqRFjheGjHOG0ycR6cXWd_wKG02g",
    authDomain:        "online-quiz-and-exam-platform.firebaseapp.com",
    projectId:         "online-quiz-and-exam-platform",
    storageBucket:     "online-quiz-and-exam-platform.firebasestorage.app",
    messagingSenderId: "1090034589767",
    appId:             "1:1090034589767:web:7942c9175cb4b28bd25162"
  });

  const auth = getAuth(app);
  const db   = getFirestore(app);

  onAuthStateChanged(auth, async user => {
    if (!user) { window.location.href = '/log'; return; }
    await loadHistory(user.uid);
  });

  async function loadHistory(uid) {
    try {
      const q    = query(
        collection(db, 'results'),
        where('userId', '==', uid),
        orderBy('completedAt', 'desc')
      );
      const snap = await getDocs(q);
      const results = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      renderHistory(results);
    } catch(err) {
      console.error(err);
    }
  }

  function timeAgo(ts) {
    if (!ts) return '';
    const d    = ts.toDate ? ts.toDate() : new Date(ts);
    const diff = Math.floor((Date.now() - d) / 1000);
    if (diff < 60)   return 'Just now';
    if (diff < 3600) return Math.floor(diff/60) + 'm ago';
    if (diff < 86400)return Math.floor(diff/3600) + 'h ago';
    return Math.floor(diff/86400) + 'd ago';
  }

  function renderHistory(results) {
    const list  = document.getElementById('history-list');
    const empty = document.getElementById('empty-state');

    // Stats
    const total  = results.length;
    const wins   = results.filter(r => r.passed).length;
    const losses = total - wins;
    document.getElementById('stat-total').textContent  = total;
    document.getElementById('stat-wins').textContent   = wins;
    document.getElementById('stat-losses').textContent = losses;

    if (total === 0) { empty.style.display = 'flex'; return; }
    empty.style.display = 'none';
    list.innerHTML = '';

    const emojis = ['📚','🔬','🌍','🧠','🎓','💡','🏆','⚡'];

    results.forEach((r, i) => {
      const win  = r.passed;
      const pct  = r.total > 0 ? Math.round((r.score / r.total) * 100) : null;

      const card = document.createElement('a');
      card.className = `quiz-card ${win ? 'win' : 'lose'}`;
      card.href = `/quiz/${r.quizId}`;
      card.innerHTML = `
        <div class="quiz-icon general">${emojis[i % emojis.length]}</div>
        <div class="quiz-info">
          <div class="quiz-name">${r.quizTitle || 'Quiz'}</div>
          <div class="quiz-meta">${timeAgo(r.completedAt)}${r.essayCount ? ' · ' + r.essayCount + ' essay' : ''}</div>
        </div>
        <div class="quiz-score">
          <div class="score-num ${win ? 'win' : 'lose'}">
            ${r.total > 0 ? r.score + '/' + r.total : '—'}
          </div>
          <div class="score-label">${pct !== null ? pct + '%' : 'Essay'}</div>
        </div>`;
      list.appendChild(card);
    });
  }
</script>

  </div>

</body>
</html>
