<!DOCTYPE html>
<html>
    <head>
        <title><%= pageTitle %></title>
        <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
        <style>
            
            :root {
                --bg-color: #ffffff;
                --text-color: #232323;
                --border-color: grey;
            }

            @media (prefers-color-scheme: dark) {
                :root {
                    --bg-color: #232323;
                    --text-color: #f8f8f8;
                    --border-color: white;
                }
            }

            body {
                background-color: var(--bg-color);
                position: fixed;
                width: 100%;
                height: 100%;
                display: flex;
                justify-content: center;
                align-items: center;
            }
            
            #container {
                min-width: 720px;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                padding: 24px;
            }

            #enteries {
                display: grid;
                grid-template-columns: 1fr 1fr;
                grid-template-areas: 
                    'login register' 
                    'about about';
                justify-content: center;
                gap: 14px;
            }

            span, 
            p {
                color: var(--text-color);
            }

            #login,
            #register,
            #about {
                display: grid;
                grid-template-columns: 80px 1fr;
                border-radius: 6px;
                border: 1px solid var(--border-color);
                padding: 10px;
                align-items: center;
            }

            #horizontal {
                width: 72px;
                height: 2px;
                background-color: var(--border-color);
                margin-bottom: 40px;
            }

            i {
                color: var(--text-color);
                user-select: none;
                font-size: 128px;
            }

        </style>
    </head>
    <body>
        <div id="container">
            <span style="font-size: 64px; margin-bottom: 48px"><%= logoName %></span>
            <div id="horizontal"></div>
            <div id="enteries">
                <div id="login" style="grid-area: login">
                    <i class="material-icons" style="font-size: 48px;">add</i>
                    <div>
                        <span style="font-size: 24px">Login</span>
                        <p>Create a new account.</p>
                    </div>
                </div>
                <div id="register" style="grid-area: register">
                    <i class="material-icons" style="font-size: 48px;">person</i>
                    <div>
                        <span style="font-size: 24px">Register</span>
                        <p>Join with your account.</p>
                    </div>
                </div>
                <div id="about" style="grid-area: about">
                    <i class="material-icons" style="font-size: 48px;">star</i>
                    <div>
                        <span style="font-size: 24px">About</span>
                        <p>View website information.</p>
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>