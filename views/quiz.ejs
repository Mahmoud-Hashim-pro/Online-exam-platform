<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <title>Quizer — Quiz</title>
        <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
        <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:        #ffffff;
            --card:      #f4f4f6;
            --card-hover:#eaeaef;
            --border:    rgba(0,0,0,0.08);
            --border-h:  rgba(0,0,0,0.18);
            --text:      #111114;
            --muted:     #666672;
            --accent:    #5a4ee8;
            --accent2:   #1aaa88;
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --bg:        #1e1e22;
                --card:      #313138;
                --card-hover:#3a3a44;
                --border:    rgba(255,255,255,0.08);
                --border-h:  rgba(255,255,255,0.18);
                --text:      #e8e8ec;
                --muted:     #8a8a98;
                --accent:    #7c6ff7;
                --accent2:   #4fcfae;
            }
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .page-header {
            display: flex;
            align-items: center;
            gap: 14px;
            padding-top: 1.4rem;
            padding-right: 1.5rem;
            margin: 0 auto;
        }

        .back-btn {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: var(--card);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background 0.15s, border-color 0.15s;
            text-decoration: none;
            flex-shrink: 0;
        }

        .back-btn:hover {
            background: var(--card-hover);
            border-color: var(--border-h);
        }

        .back-btn svg {
            stroke-width: 2;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
            stroke: var(--text);
            width: 18px;
            height: 18px;
        }

        .topbar-title {
            font-family: 'Space Mono', monospace;
            font-size: 1.15rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            background-clip: text;
        }

        .quiz-header {
            border-radius: 8px;
            margin-top: 2rem;
        }

        .urgent {
            color: #ff0000;
            padding: 4px;
            font-size: 1.2rem;
        }

        .horizontal {
            margin-top: 2rem;
            width: 100%;
            height: 2px;
            background-color: var(--border);
        }

        .stat-wrapper {

            /* TBD ... Make the position of this element less hard coded
                and more elgant */
            position: fixed;
            top: 10%;
            left: 75%;

            background-color: var(--card);
            border-radius: 10px;
            padding: 1.5rem;
            width: 15em;

            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 1rem;
        }

        .stat-wrapper svg {
            width: 24px;
            height: 24px;
            fill: var(--text);
            stroke-width: 2px;
        }

        .stat-wrapper label {
            color: var(--muted);
            text-align: center;
        }

        .submit {
            height: 2rem;
            background-color: var(--accent);
            color: var(--text);
            border-radius: 4px;
            border-color: 1px solid var(--border);
            transition: background 0.15s, border-color 0.15s;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .submit:hover {
            background-color: var(--accent2);
            border-color: 1px solid var(--border-h);
        }

        .stat-header {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .question {
            margin-top: 2rem;
        }

        .question-card {
            background-color: var(--card);
            border-radius: 10px;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 2rem;
            width: 45rem;
        }

        .question-answers-wrapper {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .answer {
            background-color: var(--bg);
            padding: 0.5rem;
            border-radius: 10px;
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            transition: background 0.15s, border-color 0.15s;
            cursor: pointer;
        }

        .answer label {
            padding: 0 0.5rem 0 0.5rem;
            color: var(--muted);
            cursor: inherit;
        }

        .answer:hover {
            background-color: var(--card-hover);
            border-color: var(--accent);
        }

        .end-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 4.5rem;
            gap: 1rem;
        }

        .end-section svg {
            width: 48px;
            height: 48px;
            stroke-width: 2px;
            stroke: var(--border-h);
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .end-section p {
            color: var(--muted);
            font-style: italic;
        }

        </style>
    </head>
    <body>
        <div class="stat-wrapper">
            <div class="stat-header">
                <svg class=stat-icon" viewBox="0 -960 960 960"><path d="M640-160v-280h160v280H640Zm-240 0v-640h160v640H400Zm-240 0v-440h160v440H160Z"/></svg>
                <!-- TBD ... Update this label using Javascript -->
                <label id="stat-solved">0/10 solved</label>
            </div>
            <label id="quiz-time">00h 00:00</label>
            <!-- <button id="submit-quiz">Submit</button> -->
            <div class="submit">Submit</div>
        </div>
        <div id="quiz-wrapper">
            <div class="page-header">
                <a href="" class="back-btn"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg></a>
                <span class="topbar-title">Quiz</span>
            </div>
            <div class="quiz-header">
                <h2>Dummpy Quiz</h2>
                <p>This is a dummpy quiz. Take your time answring!</p>
                <div class="horizontal"></div>
            </div>
            <div id="questions-wrapper">
                <!-- Questions are placed here using Javascript -->
            </div>
        </div>
        <div class="end-section">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <p>End of questions. Best of Wishes <3!</p>
        </div>
    </body>
    <script>

        var questionCounter = 0;

        function addQuestion(qinfo) {

            questionCounter++;

            // question label
            let qlabel = document.createElement('label');

            if(qinfo.urgent) {
                // question label astric
                var qlspan = document.createElement('span');
                qlspan.innerText = '*';
                qlspan.className = "urgent";
                qlabel.appendChild(qlspan);
            }

            qlabel.innerHTML += `Question ${questionCounter}`;

            // question body header
            let qbheader = document.createElement('div');
            qbheader.innerHTML = `<p>${qinfo.question}</p>`;

            // question body answers
            let qbanswers = document.createElement('div');
            qbanswers.className = "question-answers-wrapper"

            for(let i = 0; i < 4; i++) {

                // answer label
                var alabel = document.createElement('label');
                alabel.innerText = String.fromCharCode('A'.charCodeAt(0) + i);

                var answer = document.createElement('label');
                answer.innerText = qinfo.answers[i];

                // answer wrapper
                var awrapper = document.createElement('div');
                awrapper.className = "answer";
                awrapper.appendChild(alabel);
                awrapper.appendChild(answer);

                qbanswers.appendChild(awrapper);
            }

            // question body
            let qbody = document.createElement('div');
            qbody.className = "question-card";
            qbody.appendChild(qbheader);
            qbody.appendChild(qbanswers);

            // question
            let q = document.createElement('div');
            q.id = `question-${questionCounter}`
            q.className = "question"
            q.appendChild(qlabel);
            q.appendChild(qbody);

            document.querySelector('#questions-wrapper').appendChild(q);
        }

        // TBD ... Track selected answers
        // TBD ... Unchecking questions by double clicking the selected answer.

        /* add dummy question */
        addQuestion({
            urgent: 1,
            question: "Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s, when an unknown printer took a galley of type and scrambled it to make a type specimen book.",
            answers: [
                "Contrary to popular belief",
                "It is a long established fact",
                "There are many variations of passages",
                "The first line of Lorem Ipsum"
            ]
        })

        addQuestion({
            urgent: 0,
            question: "Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s, when an unknown printer took a galley of type and scrambled it to make a type specimen book.",
            answers: [
                "Contrary to popular belief",
                "It is a long established fact",
                "There are many variations of passages",
                "The first line of Lorem Ipsum"
            ]
        })

        addQuestion({
            urgent: 1,
            question: "Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s, when an unknown printer took a galley of type and scrambled it to make a type specimen book.",
            answerCount: 3,
            answers: [
                "Contrary to popular belief",
                "It is a long established fact",
                "There are many variations of passages",
                "The first line of Lorem Ipsum"
            ]
        })
    </script>
</html>