<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Quizer — Quiz</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --bg:#ffffff; --card:#f4f4f6; --card-hover:#eaeaef; --border:rgba(0,0,0,0.08); --text:#111114; --muted:#666672; --accent:#5a4ee8; --accent2:#1aaa88; --danger:#e05252; --green:#1aaa88; }
    @media (prefers-color-scheme: dark) {
      :root { --bg:#1e1e22; --card:#313138; --card-hover:#3a3a44; --border:rgba(255,255,255,0.08); --text:#e8e8ec; --muted:#8a8a98; --accent:#7c6ff7; --accent2:#4fcfae; --danger:#f27474; --green:#4fcfae; }
    }
    body { background:var(--bg); color:var(--text); font-family:'DM Sans',sans-serif; min-height:100vh; display:flex; justify-content:center; padding:2rem 1rem; }
    .page { width:100%; max-width:540px; }
    .header { display:flex; align-items:center; gap:12px; margin-bottom:1.5rem; }
    .back-btn { width:36px; height:36px; border-radius:10px; background:var(--card); border:1px solid var(--border); display:flex; align-items:center; justify-content:center; text-decoration:none; flex-shrink:0; }
    .back-btn svg { width:18px; height:18px; stroke:var(--text); fill:none; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; }
    .quiz-title { font-size:1.1rem; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

    /* Progress */
    .progress-wrap { margin-bottom:1.5rem; }
    .progress-info { display:flex; justify-content:space-between; font-size:0.78rem; color:var(--muted); margin-bottom:6px; }
    .progress-bar { height:6px; background:var(--card); border-radius:99px; overflow:hidden; }
    .progress-fill { height:100%; background:linear-gradient(90deg,var(--accent),var(--accent2)); border-radius:99px; transition:width 0.3s ease; }

    /* Question card */
    .q-card { background:var(--card); border:1px solid var(--border); border-radius:16px; padding:1.5rem; margin-bottom:1rem; }
    .q-number { font-size:0.72rem; font-weight:600; text-transform:uppercase; letter-spacing:0.07em; color:var(--muted); margin-bottom:0.6rem; }
    .q-text { font-size:1rem; font-weight:500; line-height:1.5; }

    /* Options */
    .options { display:flex; flex-direction:column; gap:10px; margin-bottom:1.5rem; }
    .option-btn {
      display:flex; align-items:center; gap:12px;
      background:var(--card); border:1.5px solid var(--border);
      border-radius:12px; padding:0.85rem 1rem;
      cursor:pointer; text-align:left; font-family:'DM Sans',sans-serif;
      font-size:0.9rem; color:var(--text);
      transition:background 0.15s, border-color 0.15s;
    }
    .option-btn:hover { background:var(--card-hover); border-color:var(--accent); }
    .option-btn.selected { border-color:var(--accent); background:rgba(90,78,232,0.08); }
    .option-btn.correct  { border-color:var(--green);  background:rgba(26,170,136,0.1); }
    .option-btn.wrong    { border-color:var(--danger);  background:rgba(224,82,82,0.08); }
    .option-letter { width:28px; height:28px; border-radius:8px; background:rgba(90,78,232,0.12); display:flex; align-items:center; justify-content:center; font-size:0.75rem; font-weight:700; color:var(--accent); flex-shrink:0; }

    /* Nav */
    .nav { display:flex; gap:10px; }
    .nav-btn { flex:1; padding:0.85rem; border-radius:12px; border:1px solid var(--border); background:var(--card); color:var(--text); font-family:'DM Sans',sans-serif; font-size:0.9rem; font-weight:500; cursor:pointer; transition:background 0.15s; }
    .nav-btn:hover { background:var(--card-hover); }
    .nav-btn.primary { background:linear-gradient(135deg,var(--accent),var(--accent2)); border:none; color:#fff; font-weight:600; }
    .nav-btn:disabled { opacity:0.4; cursor:not-allowed; }

    /* Result */
    .result { display:none; text-align:center; padding:2rem 1rem; }
    .result.show { display:block; }
    .result-score { font-family:'Space Mono',monospace; font-size:3.5rem; font-weight:700; background:linear-gradient(135deg,var(--accent),var(--accent2)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .result-label { font-size:1rem; font-weight:500; margin:0.4rem 0 1.5rem; color:var(--muted); }
    .result-msg { font-size:1.1rem; font-weight:600; margin-bottom:1.5rem; }
    .result-btn { padding:0.85rem 2rem; border-radius:12px; border:none; background:linear-gradient(135deg,var(--accent),var(--accent2)); color:#fff; font-family:'DM Sans',sans-serif; font-size:0.95rem; font-weight:600; cursor:pointer; }

    /* Loading */
    .loading { text-align:center; padding:4rem 1rem; color:var(--muted); font-size:0.9rem; }
    .loading svg { width:40px; height:40px; stroke:var(--muted); fill:none; stroke-width:1.5; margin:0 auto 1rem; display:block; animation:spin 1s linear infinite; }
    .essay-textarea { width:100%; min-height:120px; background:var(--card); border:1px solid var(--border); border-radius:12px; padding:12px; font-family:'DM Sans',sans-serif; font-size:0.9rem; color:var(--text); outline:none; resize:vertical; transition:border-color 0.15s, box-shadow 0.15s; }
    .essay-textarea:focus { border-color:var(--accent); box-shadow:0 0 0 3px rgba(90,78,232,0.12); }
    .essay-label { font-size:0.8rem; color:var(--muted); margin-bottom:8px; display:block; }
    @keyframes spin { to { transform:rotate(360deg); } }
  </style>
</head>
<body>
<div class="page">

  <!-- Loading -->
  <div class="loading" id="loading">
    <svg viewBox="0 0 24 24"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
    Loading quiz...
  </div>

  <!-- Quiz UI -->
  <div id="quiz-ui" style="display:none;">
    <div class="header">
      <a href="/search" class="back-btn">
        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      </a>
      <div class="quiz-title" id="quiz-title-el">Quiz</div>
    </div>

    <div class="progress-wrap">
      <div class="progress-info">
        <span id="progress-text">Question 1 of 1</span>
        <span id="progress-pct">0%</span>
      </div>
      <div class="progress-bar"><div class="progress-fill" id="progress-fill" style="width:0%"></div></div>
    </div>

    <div class="q-card">
      <div class="q-number" id="q-number">QUESTION 1</div>
      <div class="q-text" id="q-text"></div>
    </div>

    <div class="options" id="options"></div>

    <div class="nav">
      <button class="nav-btn" id="prev-btn" onclick="prevQ()">← Previous</button>
      <button class="nav-btn primary" id="next-btn" onclick="nextQ()">Next →</button>
    </div>
  </div>

  <!-- Result -->
  <div class="result" id="result">
    <div class="result-score" id="result-score">0/0</div>
    <div class="result-label">Your Score</div>
    <div class="result-msg" id="result-msg"></div>
    <button class="result-btn" onclick="window.location.href='/history'">View History</button>
  </div>

</div>

<script type="module">
  import { initializeApp }               from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js';
  import { getAuth, onAuthStateChanged } from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js';
  import { getFirestore, doc, getDoc }   from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js';

  const firebaseConfig = {
    apiKey:            "AIzaSyC_bAMVqRFjheGjHOG0ycR6cXWd_wKG02g",
    authDomain:        "online-quiz-and-exam-platform.firebaseapp.com",
    projectId:         "online-quiz-and-exam-platform",
    storageBucket:     "online-quiz-and-exam-platform.firebasestorage.app",
    messagingSenderId: "1090034589767",
    appId:             "1:1090034589767:web:7942c9175cb4b28bd25162"
  };

  const app  = initializeApp(firebaseConfig);
  const auth = getAuth(app);
  const db   = getFirestore(app);

  // جيب الـ quiz ID من الـ URL
  const quizId = window.location.pathname.split('/').pop();

  let quiz      = null;
  let current   = 0;
  let answers   = {};

  onAuthStateChanged(auth, async user => {
    if (!user) { window.location.href = '/log'; return; }
    await loadQuiz();
  });

  async function loadQuiz() {
    try {
      const snap = await getDoc(doc(db, 'quizzes', quizId));
      if (!snap.exists()) { document.getElementById('loading').textContent = 'Quiz not found!'; return; }
      quiz = { id: snap.id, ...snap.data() };
      document.getElementById('loading').style.display = 'none';
      document.getElementById('quiz-ui').style.display = 'block';
      document.getElementById('quiz-title-el').textContent = quiz.title;
      showQuestion(0);
    } catch (err) {
      document.getElementById('loading').textContent = 'Error loading quiz: ' + err.message;
    }
  }

  function showQuestion(idx) {
    const q   = quiz.questions[idx];
    const tot = quiz.questions.length;
    current   = idx;

    const pct = Math.round((idx / tot) * 100);
    document.getElementById('progress-text').textContent = `Question ${idx+1} of ${tot}`;
    document.getElementById('progress-pct').textContent  = pct + '%';
    document.getElementById('progress-fill').style.width = pct + '%';
    document.getElementById('q-number').textContent = `QUESTION ${idx+1}`;
    document.getElementById('q-text').textContent   = q.text;

    const optDiv = document.getElementById('options');
    optDiv.innerHTML = '';

    if (q.type === 'essay') {
      // Essay — textarea
      const label = document.createElement('span');
      label.className = 'essay-label';
      label.textContent = 'Write your answer:';
      optDiv.appendChild(label);

      const ta = document.createElement('textarea');
      ta.className   = 'essay-textarea';
      ta.id          = 'essay-' + idx;
      ta.placeholder = 'Type your answer here…';
      ta.value       = answers[idx] || '';
      ta.oninput     = () => { answers[idx] = ta.value; };
      optDiv.appendChild(ta);

    } else if (q.type === 'tf') {
      // True / False
      ['True','False'].forEach(val => {
        const btn = document.createElement('button');
        btn.className = 'option-btn';
        if (answers[idx] === val) btn.classList.add('selected');
        btn.innerHTML = `<span class="option-letter">${val === 'True' ? '✅' : '❌'}</span>${val}`;
        btn.onclick = () => selectAnswer(idx, val, 'tf');
        optDiv.appendChild(btn);
      });
    } else {
      // MCQ
      const letters = ['A','B','C','D'];
      letters.forEach(l => {
        if (!q.options || !q.options[l]) return;
        const btn = document.createElement('button');
        btn.className = 'option-btn';
        if (answers[idx] === l) btn.classList.add('selected');
        btn.innerHTML = `<span class="option-letter">${l}</span>${q.options[l]}`;
        btn.onclick = () => selectAnswer(idx, l, 'mcq');
        optDiv.appendChild(btn);
      });
    }

    document.getElementById('prev-btn').disabled = idx === 0;
    document.getElementById('next-btn').textContent = idx === tot-1 ? 'Submit ✅' : 'Next →';
  }

  function selectAnswer(idx, value, type) {
    answers[idx] = value;
    document.querySelectorAll('.option-btn').forEach(btn => {
      const label = btn.querySelector('.option-letter').textContent;
      const match = type === 'tf'
        ? (value === 'True' ? '✅' : '❌') === label
        : label === value;
      btn.classList.toggle('selected', match);
    });
  }

  window.prevQ = function() { if (current > 0) showQuestion(current - 1); };

  window.nextQ = function() {
    if (current < quiz.questions.length - 1) {
      showQuestion(current + 1);
    } else {
      showResult();
    }
  };

  function showResult() {
    // احسب بس الأسئلة اللي ليها إجابة صح (MCQ + TF)
    let score    = 0;
    let gradable = 0;
    let essayCount = 0;

    quiz.questions.forEach((q, i) => {
      if (q.type === 'essay') {
        essayCount++;
      } else {
        gradable++;
        if (answers[i] === q.correct) score++;
      }
    });

    const pct = gradable > 0 ? Math.round((score / gradable) * 100) : 0;

    document.getElementById('quiz-ui').style.display = 'none';
    document.getElementById('result').classList.add('show');
    document.getElementById('result-score').textContent =
      gradable > 0 ? `${score}/${gradable}` : '—';

    let msg = pct >= 80 ? 'Excellent work!' :
              pct >= 60 ? 'Good job!' :
              pct >= 40 ? 'Keep practicing!' : 'Try again!';

    if (essayCount > 0) {
      msg += `
📝 ${essayCount} essay question${essayCount > 1 ? 's' : ''} will be reviewed manually.`;
    }

    document.getElementById('result-msg').textContent = msg;
  }
</script>
</body>
</html>
